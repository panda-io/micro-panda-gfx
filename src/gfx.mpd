// panda_gfx — direct-mode GFX library
// No framebuffer. Adafruit GFX style.
// Driver table is owned by gfx; host fills it via gfx_driver().

// ── driver table ──────────────────────────────────────────────────────────────

class GfxDriver
    width:     i32
    height:    i32
    set_pixel: &fun(x: i32, y: i32, color: i32)
    fill_rect: &fun(x: i32, y: i32, w: i32, h: i32, color: i32)

var _driver: GfxDriver

// Return reference to the driver table. Host fills fields then calls gfx_init().
fun gfx_driver() &GfxDriver
    return &_driver

// Finalize init after driver table is filled. Call once.
fun gfx_init()
    return

fun gfx_width() i32
    return _driver.width

fun gfx_height() i32
    return _driver.height

// ── C helpers ─────────────────────────────────────────────────────────────────

