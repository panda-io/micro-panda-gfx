// panda_gfx — strip-buffer GFX library.
// GFX owns the strip buffer; driver receives it via flush(x, y, w, h, buf).
// Driver table is owned by gfx; host fills it via gfx_driver().

import rotation::*
import pixel_format::*
import node::*

// ── driver table ──────────────────────────────────────────────────────────────

class GfxDriver
    var width:  i32
    var height: i32
    var flush:  fun(i32, i32, i32, i32, u8[])   // x, y, w, h, buf

var _driver:       GfxDriver
var _strip:        u8[]                        // GFX-owned strip buffer
var _format:       PixelFormat                 // physical pixel format
var _view_w:       i32
var _view_h:       i32
var _fill_fn:      fun(i32, i32, i32, i32, i32)  // logical fill → physical strip (rotation-aware)
var _phys_fill_fn: fun(i32, i32, i32, i32, i32)  // write rect at physical coords to _strip

// Return reference to the driver table. Host fills fields then calls gfx_set_strip() + gfx_init().
fun gfx_driver() &GfxDriver
    return &_driver

// ── physical strip-buffer pixel writers ───────────────────────────────────────
// Write to _strip at physical (px, py) in the current _format.

fun _strip_pixel_mono(px: i32, py: i32, color: i32)
    val stride: i32 = (_driver.width + 7) / 8
    val idx: i32    = py * stride + px / 8
    if color != 0
        _strip[idx] = _strip[idx] | u8(0x80 >> (px & 7))
    else
        _strip[idx] = _strip[idx] & u8(~(0x80 >> (px & 7)))

fun _strip_fill_mono(px: i32, py: i32, w: i32, h: i32, color: i32)
    var iy: i32 = py
    while iy < py + h
        var ix: i32 = px
        while ix < px + w
            _strip_pixel_mono(ix, iy, color)
            ix += 1
        iy += 1

fun _strip_pixel_rgb565(px: i32, py: i32, color: i32)
    val idx: i32    = (py * _driver.width + px) * 2
    _strip[idx]     = u8(color >> 8)
    _strip[idx + 1] = u8(color)

fun _strip_fill_rgb565(px: i32, py: i32, w: i32, h: i32, color: i32)
    var iy: i32 = py
    while iy < py + h
        var ix: i32 = px
        while ix < px + w
            _strip_pixel_rgb565(ix, iy, color)
            ix += 1
        iy += 1

// ── rotation-specialised fill functions ───────────────────────────────────────
// Map logical rect to physical coords, then write to _strip via _phys_fill_fn.

fun _fill_r0(x: i32, y: i32, w: i32, h: i32, color: i32)
    _phys_fill_fn(x, y, w, h, color)

fun _fill_r90(x: i32, y: i32, w: i32, h: i32, color: i32)
    _phys_fill_fn(_driver.width - y - h, x, h, w, color)

fun _fill_r180(x: i32, y: i32, w: i32, h: i32, color: i32)
    _phys_fill_fn(_driver.width - x - w, _driver.height - y - h, w, h, color)

fun _fill_r270(x: i32, y: i32, w: i32, h: i32, color: i32)
    _phys_fill_fn(y, _driver.height - x - w, h, w, color)

// Set rotation and update logical dimensions + fill dispatch.
// Call after gfx_init() or any time to re-orient the display.
fun gfx_set_rotation(r: Rotation)
    if r == Rotation.R0
        _fill_fn = _fill_r0
        _view_w  = _driver.width
        _view_h  = _driver.height
    if r == Rotation.R90
        _fill_fn = _fill_r90
        _view_w  = _driver.height
        _view_h  = _driver.width
    if r == Rotation.R180
        _fill_fn = _fill_r180
        _view_w  = _driver.width
        _view_h  = _driver.height
    if r == Rotation.R270
        _fill_fn = _fill_r270
        _view_w  = _driver.height
        _view_h  = _driver.width

// Set the strip buffer and pixel format. Call before gfx_init().
fun gfx_set_strip(buf: u8[], fmt: PixelFormat)
    _strip  = buf
    _format = fmt

// Init after driver table and strip buffer are set. Defaults to R0.
fun gfx_init()
    if _format == PixelFormat.Mono
        _phys_fill_fn = _strip_fill_mono
    if _format == PixelFormat.RGB565
        _phys_fill_fn = _strip_fill_rgb565
    gfx_set_rotation(Rotation.R0)

fun gfx_width() i32
    return _view_w

fun gfx_height() i32
    return _view_h

// ── C helpers ─────────────────────────────────────────────────────────────────

