static inline uint8_t __mp_gfx_font_row(uint8_t c, int row) {
    return __mp_gfx_font[c][row];
}
""")

@extern("__mp_gfx_font_row")
fun _font_row(c: u8, row: i32) u8

// ── text (TODO: move to font node) ────────────────────────────────────────────

// Draw one CP437 character at pixel (x, y).
// scale: 1–8, each font pixel becomes a scale×scale block.
// bg = -1 for transparent background.
fun _char_raw(x: i32, y: i32, c: u8, color: i32, bg: i32, scale: i32)
    var row: i32 = 0
    while row < 8
        var bits: u8 = _font_row(c, row)
        var col: i32 = 0
        while col < 8
            if (bits & u8(0x80 >> col)) != 0
                _fill_fn(x + col * scale, y + row * scale, scale, scale, color)
            else
                if bg >= 0
                    _fill_fn(x + col * scale, y + row * scale, scale, scale, bg)
            col += 1
        row += 1

// Draw one CP437 character at pixel (x, y).
// scale: 1–8, each font pixel becomes a scale×scale block.
// bg = -1 for transparent background.
fun gfx_char(x: i32, y: i32, c: u8, color: i32, bg: i32, scale: i32)
    _char_raw(x, y, c, color, bg, scale)
    _driver.flush(0, 0, _driver.width, _driver.height, _strip)

// Draw len bytes of s as CP437 characters starting at (x, y).
// Glyph advance = (8 + 1) * scale pixels.
// bg = -1 for transparent background.
// Returns x position after the last character.
fun gfx_str(x: i32, y: i32, s: u8[], color: i32, bg: i32, scale: i32) i32
    var i: i32 = 0
    var cx: i32 = x
    while i < i32(s.size())
        _char_raw(cx, y, s[i], color, bg, scale)
        cx += 9 * scale
        i += 1
    _driver.flush(0, 0, _driver.width, _driver.height, _strip)
    return cx

// ── node render ───────────────────────────────────────────────────────────────
// Render a node tree into the driver, applying bias_x/bias_y offsets.
// Canvas nodes: their pixel buffer is passed directly to the driver flush —
// no copy into _strip needed.

fun gfx_render(node: &Node, bias_x: i32, bias_y: i32)
    match node
        Canvas(c):
            _driver.flush(c.x + bias_x, c.y + bias_y, c.width, c.height, c.buf)

