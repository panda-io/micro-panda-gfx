    {0x3C,0x66,0x0C,0x18,0x00,0x7E,0x00,0x00}, // FC ⁿ
    {0x3C,0x66,0x0C,0x18,0x30,0x66,0x3C,0x00}, // FD ²
    {0x00,0xFF,0xDB,0xDB,0xDB,0xFF,0x00,0x00}, // FE ■
    {0x00,0x00,0x00,0x00,0x00,0x00,0x00,0x00}, // FF NBSP
};

static inline uint8_t __mp_gfx_font_row(uint8_t c, int row) {
    return __mp_gfx_font[c][row];
}

static inline int32_t __mp_gfx_abs(int32_t v) { return v < 0 ? -v : v; }
static inline int32_t __mp_gfx_sign(int32_t v) { return v > 0 ? 1 : (v < 0 ? -1 : 0); }

static inline int32_t __mp_gfx_isqrt(int32_t n) {
    if (n <= 0) return 0;
    int32_t x = n, y = (x + 1) / 2;
    while (y < x) { x = y; y = (x + n / x) / 2; }
    return x;
}
""")

@extern("__mp_gfx_font_row")
fun _font_row(c: u8, row: i32) u8

@extern("__mp_gfx_abs")
fun _abs(v: i32) i32

@extern("__mp_gfx_sign")
fun _sign(v: i32) i32

@extern("__mp_gfx_isqrt")
fun _isqrt(n: i32) i32

// ── core primitives ───────────────────────────────────────────────────────────

@inline
fun gfx_pixel(x: i32, y: i32, color: i32)
    if x < 0 || x >= _driver.width || y < 0 || y >= _driver.height
        return
    _driver.set_pixel(x, y, color)

fun gfx_hline(x: i32, y: i32, w: i32, color: i32)
    if w <= 0 || y < 0 || y >= _driver.height
        return
    if x < 0
        w += x
        x = 0
    if x + w > _driver.width
        w = _driver.width - x
    if w <= 0
        return
    _driver.fill_rect(x, y, w, 1, color)

fun gfx_vline(x: i32, y: i32, h: i32, color: i32)
    if h <= 0 || x < 0 || x >= _driver.width
        return
    if y < 0
        h += y
        y = 0
    if y + h > _driver.height
        h = _driver.height - y
    if h <= 0
        return
    _driver.fill_rect(x, y, 1, h, color)

fun gfx_line(x0: i32, y0: i32, x1: i32, y1: i32, color: i32)
    var dx: i32 = _abs(x1 - x0)
    var dy: i32 = _abs(y1 - y0)
    var sx: i32 = _sign(x1 - x0)
    var sy: i32 = _sign(y1 - y0)
    var err: i32 = dx - dy
    while true
        gfx_pixel(x0, y0, color)
        if x0 == x1 && y0 == y1
            return
        var e2: i32 = err * 2
        if e2 > -dy
            err -= dy
            x0 += sx
        if e2 < dx
            err += dx
            y0 += sy

// ── rectangles ────────────────────────────────────────────────────────────────

fun gfx_rect(x: i32, y: i32, w: i32, h: i32, color: i32)
    gfx_hline(x, y, w, color)
    gfx_hline(x, y + h - 1, w, color)
    gfx_vline(x, y + 1, h - 2, color)
    gfx_vline(x + w - 1, y + 1, h - 2, color)

fun gfx_fill_rect(x: i32, y: i32, w: i32, h: i32, color: i32)
    _driver.fill_rect(x, y, w, h, color)

fun gfx_clear(color: i32)
    gfx_fill_rect(0, 0, _driver.width, _driver.height, color)

// ── circles ───────────────────────────────────────────────────────────────────

fun _circle_8(cx: i32, cy: i32, x: i32, y: i32, color: i32)
    gfx_pixel(cx + x, cy + y, color)
    gfx_pixel(cx - x, cy + y, color)
    gfx_pixel(cx + x, cy - y, color)
    gfx_pixel(cx - x, cy - y, color)
    gfx_pixel(cx + y, cy + x, color)
    gfx_pixel(cx - y, cy + x, color)
    gfx_pixel(cx + y, cy - x, color)
    gfx_pixel(cx - y, cy - x, color)

fun gfx_circle(cx: i32, cy: i32, r: i32, color: i32)
    var x: i32 = 0
    var y: i32 = r
    var d: i32 = 1 - r
    _circle_8(cx, cy, x, y, color)
    while x < y
        if d < 0
            d += 2 * x + 3
        else
            d += 2 * (x - y) + 5
            y -= 1
        x += 1
        _circle_8(cx, cy, x, y, color)

fun gfx_fill_circle(cx: i32, cy: i32, r: i32, color: i32)
    var dy: i32 = -r
    while dy <= r
        var dx: i32 = _isqrt(r * r - dy * dy)
        gfx_hline(cx - dx, cy + dy, dx * 2 + 1, color)
        dy += 1

// ── triangles ─────────────────────────────────────────────────────────────────

fun gfx_triangle(x0: i32, y0: i32, x1: i32, y1: i32, x2: i32, y2: i32, color: i32)
    gfx_line(x0, y0, x1, y1, color)
    gfx_line(x1, y1, x2, y2, color)
    gfx_line(x2, y2, x0, y0, color)

fun gfx_fill_triangle(x0: i32, y0: i32, x1: i32, y1: i32, x2: i32, y2: i32, color: i32)
    // sort vertices by y: y0 <= y1 <= y2
    var tx: i32 = 0
    var ty: i32 = 0
    if y1 < y0
        tx = x0  ty = y0  x0 = x1  y0 = y1  x1 = tx  y1 = ty
    if y2 < y0
        tx = x0  ty = y0  x0 = x2  y0 = y2  x2 = tx  y2 = ty
    if y2 < y1
        tx = x1  ty = y1  x1 = x2  y1 = y2  x2 = tx  y2 = ty
    var y: i32 = y0
    while y <= y2
        var xa: i32 = 0
        var xb: i32 = 0
        if y <= y1 && y1 != y0
            xa = x0 + (y - y0) * (x1 - x0) / (y1 - y0)
        else
            xa = x1
        if y2 != y0
            xb = x0 + (y - y0) * (x2 - x0) / (y2 - y0)
        else
            xb = x0
        if xa > xb
            tx = xa  xa = xb  xb = tx
        gfx_hline(xa, y, xb - xa + 1, color)
        y += 1

// ── rounded rectangles ────────────────────────────────────────────────────────

fun gfx_round_rect(x: i32, y: i32, w: i32, h: i32, r: i32, color: i32)
    gfx_hline(x + r, y, w - 2 * r, color)
    gfx_hline(x + r, y + h - 1, w - 2 * r, color)
    gfx_vline(x, y + r, h - 2 * r, color)
    gfx_vline(x + w - 1, y + r, h - 2 * r, color)
    var px: i32 = 0
    var py: i32 = r
    var d: i32 = 1 - r
    while px <= py
        gfx_pixel(x + w - 1 - r + py, y + r - px, color)
        gfx_pixel(x + r - py,          y + r - px, color)
        gfx_pixel(x + w - 1 - r + py, y + h - 1 - r + px, color)
        gfx_pixel(x + r - py,          y + h - 1 - r + px, color)
        gfx_pixel(x + w - 1 - r + px, y + r - py, color)
        gfx_pixel(x + r - px,          y + r - py, color)
        gfx_pixel(x + w - 1 - r + px, y + h - 1 - r + py, color)
        gfx_pixel(x + r - px,          y + h - 1 - r + py, color)
        if d < 0
            d += 2 * px + 3
        else
            d += 2 * (px - py) + 5
            py -= 1
        px += 1

fun gfx_fill_round_rect(x: i32, y: i32, w: i32, h: i32, r: i32, color: i32)
    gfx_fill_rect(x + r, y, w - 2 * r, h, color)
    var px: i32 = 0
    var py: i32 = r
    var d: i32 = 1 - r
    while px <= py
        gfx_hline(x + w - 1 - r - py + 1, y + r - px, py * 2 - 1, color)
        gfx_hline(x + w - 1 - r - py + 1, y + h - 1 - r + px, py * 2 - 1, color)
        gfx_hline(x + w - 1 - r - px + 1, y + r - py, px * 2 - 1, color)
        gfx_hline(x + w - 1 - r - px + 1, y + h - 1 - r + py, px * 2 - 1, color)
        if d < 0
            d += 2 * px + 3
        else
            d += 2 * (px - py) + 5
            py -= 1
        px += 1

// ── text ──────────────────────────────────────────────────────────────────────

// Draw one CP437 character (8×8) at pixel (x, y).
// bg = -1 for transparent background.
fun gfx_char(x: i32, y: i32, c: u8, color: i32, bg: i32)
    var row: i32 = 0
    while row < 8
        var bits: u8 = _font_row(c, row)
        var col: i32 = 0
        while col < 8
            if bits & u8(0x80 >> col) != 0
                gfx_pixel(x + col, y + row, color)
            else
                if bg >= 0
                    gfx_pixel(x + col, y + row, bg)
            col += 1
        row += 1

// Draw len bytes of s as CP437 characters starting at (x, y).
// Each glyph is 8×8 px; use x-spacing of 9 for a 1-pixel gap.
// bg = -1 for transparent background.
// Returns x position after the last character.
fun gfx_str(x: i32, y: i32, s: u8[], len: i32, color: i32, bg: i32) i32
    var i: i32 = 0
    var cx: i32 = x
    while i < len
        gfx_char(cx, y, s[i], color, bg)
        cx += 9
        i += 1
    return cx

